#!/bin/bash

BOLD=$'\e[1m'
GREEN=$'\e[32m'
RED=$'\e[31m'
YELLOW=$'\e[33m'
BLUE=$'\e[34m'
CYAN=$'\e[36m'
RESET=$'\e[m'

printf "\n${BOLD}Compiling...${RESET}\n\n"
make re || exit 1

TEST_DIR="/tmp/test"
TEST_DIR2="/tmp/test2"
TIMEOUT=1
SIGNATURE="War version 1.0 (c)oded"

# ------------------------------------------------
# Enable / Disable tests by commenting lines
# ------------------------------------------------

TARGETS=(
ls
grep
cat
wc
cp
mv
rm
mkdir
rmdir
touch
chmod
chown
pwd
whoami
id
uname
hostname
date
sleep
true
false
head
tail
cut
sort
uniq
basename
dirname
realpath
stat
)

# ------------------------------------------------
# Manual tests
# ------------------------------------------------

declare -A TESTS

TESTS[ls]="ls /bin | head -n 5"
TESTS[cat]="echo hello | cat"
TESTS[cp]="cp /bin/ls /tmp/test_copy && rm -f /tmp/test_copy"
TESTS[mv]="touch /tmp/a && mv /tmp/a /tmp/b && rm -f /tmp/b"
TESTS[rm]="touch /tmp/r && rm /tmp/r"
TESTS[mkdir]="mkdir -p /tmp/test_dir && rmdir /tmp/test_dir"
TESTS[rmdir]="mkdir -p /tmp/test_dir && rmdir /tmp/test_dir"
TESTS[touch]="touch /tmp/a && rm -f /tmp/a"
TESTS[chmod]="touch /tmp/b && chmod 600 /tmp/b && rm -f /tmp/b"
TESTS[chown]="touch /tmp/c 2>/dev/null || true"
TESTS[pwd]="pwd"
TESTS[whoami]="whoami"
TESTS[id]="id"
TESTS[uname]="uname -a"
TESTS[hostname]="hostname"
TESTS[date]="date +%s"
TESTS[sleep]="sleep 0"
TESTS[true]="true"
TESTS[false]="false"
TESTS[grep]="printf 'a\nb\n' | grep a"
TESTS[wc]="printf 'a\nb\nc\n' | wc -l"
TESTS[head]="ls /bin | head -n 2"
TESTS[tail]="ls /bin | tail -n 2"
TESTS[cut]="echo 'a:b:c' | cut -d: -f2"
TESTS[sort]="printf 'c\nb\na\n' | sort"
TESTS[uniq]="printf 'a\na\nb\n' | uniq"
TESTS[basename]="basename /usr/bin/ls"
TESTS[dirname]="dirname /usr/bin/ls"
TESTS[realpath]="realpath /bin/ls"
TESTS[stat]="stat /bin/ls"

# ------------------------------------------------
# Global counters
# ------------------------------------------------

TOTAL=0
BEHAVIOR_OK=0
SIGNATURE_OK=0
ANTIDEBUG_OK=0
ANTIDEBUG_TOTAL=0
CHANGE_SIG_OK=0
FAIL_SIG_CHANGE=0
CHAIN_BROKEN=0

# Deferred diff lines, flushed after each step row
PENDING_DIFFS=()

# ------------------------------------------------
# run_test <bin>
# Prints fixed-width inline result for one binary.
# Behavior KO diffs are appended to PENDING_DIFFS[].
# Updates global TOTAL, BEHAVIOR_OK, SIGNATURE_OK.
# ------------------------------------------------

run_test() {
    local bin="$1"
    local INF="$TEST_DIR/$bin"
    local OG
    OG="$(which "$bin" 2>/dev/null)"

    if [ ! -x "$INF" ]; then
        printf " ${YELLOW}%-8s ? %-12s${RESET}" "$bin" "[MISS]"
        return
    fi

    ((TOTAL++))

    local cmd="${TESTS[$bin]}"
    if [[ -z "$cmd" ]]; then
        printf " ${YELLOW}%-8s ? %-12s${RESET}" "$bin" "[NOTEST]"
        return
    fi

    local cmd_og="${cmd//$bin/$OG}"
    local cmd_inf="${cmd//$bin/$INF}"

    local OUT1 OUT2 RC1 RC2
    OUT1=$(timeout "$TIMEOUT" bash -c "$cmd_og" 2>&1); RC1=$?
    OUT2=$(timeout "$TIMEOUT" bash -c "$cmd_inf" 2>&1); RC2=$?
    sleep 1

    # Behavior symbol
    local beh_sym beh_col
    if [ "$RC1" -eq 124 ] || [ "$RC2" -eq 124 ]; then
        beh_sym="~" ; beh_col="$YELLOW"
    elif [ "$OUT1" == "$OUT2" ] && [ "$RC1" == "$RC2" ]; then
        beh_sym="Ō£ō" ; beh_col="$GREEN"
        ((BEHAVIOR_OK++))
    else
        beh_sym="Ō£Ś" ; beh_col="$RED"
        # Buffer the diff ŌĆö flushed after the full row is printed
        local og_line inf_line
        og_line="$(echo "$OUT1" | head -1)"
        inf_line="$(echo "$OUT2" | head -1)"
        PENDING_DIFFS+=("$(printf "         ${RED}%-8s Ōå│ OG : %s [\$?=%d]${RESET}" "$bin" "$og_line" "$RC1")")
        PENDING_DIFFS+=("$(printf "         ${RED}%-8s Ōå│ INF: %s [\$?=%d]${RESET}" "$bin" "$inf_line" "$RC2")")
    fi

    # Signature field
    local sig_count id_sign sig_str sig_col
    sig_count=$(strings "$INF" | grep -c "$SIGNATURE")
    id_sign=$(strings "$INF" | grep "$SIGNATURE" | grep -o '\[[0-9A-F]*\]' | tr -d '[]')
    if [ "$sig_count" -eq 1 ]; then
        if [ "$id_sign" = "42694269" ]; then
            sig_str="[${id_sign}]" ; sig_col="$RED"
        else
            sig_str="[${id_sign}]" ; sig_col="$GREEN"
            ((SIGNATURE_OK++))
        fi
    elif [ "$sig_count" -gt 1 ]; then
        sig_str="[x${sig_count}]" ; sig_col="$RED"
    else
        sig_str="[NOSIG]" ; sig_col="$RED"
    fi

    printf " ${BOLD}%-8s${RESET} ${beh_col}${beh_sym}${RESET} ${sig_col}%-12s${RESET}" \
        "$bin" "$sig_str"
}

# ------------------------------------------------
# flush_diffs
# Prints any buffered KO diff lines then clears them
# ------------------------------------------------

flush_diffs() {
    if [ "${#PENDING_DIFFS[@]}" -gt 0 ]; then
        for line in "${PENDING_DIFFS[@]}"; do
            printf "%b\n" "$line"
        done
    fi
    PENDING_DIFFS=()
}

# ------------------------------------------------
# antidebug_test <label> <infector_path>
# ------------------------------------------------

antidebug_test() {
    local label="$1"
    local infector="$2"
    local victim_src victim_path_1 victim_path_2 sig_count

    victim_src="$(which echo 2>/dev/null)"
    victim_path_1="$TEST_DIR/echo"
    victim_path_2="$TEST_DIR2/echo"

    ((ANTIDEBUG_TOTAL++))

    if [ ! -x "$infector" ]; then
        printf "  ${YELLOW}%-45s ?  SKIP${RESET}\n" "$label"
        return
    fi

    cp "$victim_src" "$victim_path_1"
    cp "$victim_src" "$victim_path_2"

    timeout "$((TIMEOUT * 8))" \
        gdb -batch \
            -ex "set follow-fork-mode child" \
            -ex run \
            --args "$infector" \
        </dev/null >/dev/null 2>/dev/null

    sleep 1

    sig_count=$(strings "$victim_path_1" | grep -c "$SIGNATURE")
    rm -f "$victim_path_1" "$victim_path_2"

    if [ "$sig_count" -eq 0 ]; then
        printf "  ${BOLD}%-45s${RESET} ${GREEN}Ō£ō  OK${RESET} (victim stayed clean)\n" "$label"
        ((ANTIDEBUG_OK++))
    else
        printf "  ${BOLD}%-45s${RESET} ${RED}Ō£Ś  KO${RESET} (infected despite being debugged)\n" "$label"
    fi
}

# ------------------------------------------------
# antiprocess_test <label> <infector_path>
# ------------------------------------------------

antiprocess_test() {
    local label="$1"
    local infector="$2"
    local victim_src victim_path_1 victim_path_2 sig_count doom_pid

    victim_src="$(which echo 2>/dev/null)"
    victim_path_1="$TEST_DIR/echo"
    victim_path_2="$TEST_DIR2/echo"

    ((ANTIDEBUG_TOTAL++))

    if [ ! -x "$infector" ]; then
        printf "  ${YELLOW}%-45s ?  SKIP${RESET}\n" "$label"
        return
    fi

    cp "$victim_src" "$victim_path_1"
    cp "$victim_src" "$victim_path_2"
    cc test/infinity.c -o doom-nukem
    ./doom-nukem &
    doom_pid=$!

    timeout "$((TIMEOUT * 8))" "$infector" </dev/null >/dev/null 2>/dev/null

    sleep 3

    kill "$doom_pid" 2>/dev/null
    wait "$doom_pid" 2>/dev/null
    rm -f /tmp/doom-nukem

    sig_count=$(strings "$victim_path_1" | grep -c "$SIGNATURE")
    rm -f "$victim_path_1" "$victim_path_2"

    if [ "$sig_count" -eq 0 ]; then
        printf "  ${BOLD}%-45s${RESET} ${GREEN}Ō£ō  OK${RESET} (victim stayed clean)\n" "$label"
        ((ANTIDEBUG_OK++))
    else
        printf "  ${BOLD}%-45s${RESET} ${RED}Ō£Ś  KO${RESET} (infected despite doom-nukem running)\n" "$label"
    fi
}

# ------------------------------------------------
# Setup
# ------------------------------------------------

rm -rf "$TEST_DIR" "$TEST_DIR2"
mkdir -p "$TEST_DIR" "$TEST_DIR2"

# ------------------------------------------------
# Chain infection + interleaved testing
# ------------------------------------------------

printf "\n${BOLD}======= Chain Infection + Behavior Tests =======${RESET}\n\n"

NUM_TARGETS=${#TARGETS[@]}

for (( i = 0; i < NUM_TARGETS; i += 2 )); do

    bin_a="${TARGETS[$i]}"
    bin_b=""
    (( i + 1 < NUM_TARGETS )) && bin_b="${TARGETS[$((i + 1))]}"

    if (( i == 0 )); then
        infector="$(pwd)/war"
        infector_label="war"
    else
        infector="$TEST_DIR/${TARGETS[$((i - 1))]}"
        infector_label="${TARGETS[$((i - 1))]}"
    fi

    src_a="$(which "$bin_a" 2>/dev/null)"
    if [ -z "$src_a" ]; then
        printf "${YELLOW}ŌÜĀ '%s' not found, skipping pair${RESET}\n" "$bin_a"
        continue
    fi
    cp "$src_a" "$TEST_DIR/$bin_a"
    cp "$src_a" "$TEST_DIR2/$bin_a"

    if [ -n "$bin_b" ]; then
        src_b="$(which "$bin_b" 2>/dev/null)"
        if [ -n "$src_b" ]; then
            cp "$src_b" "$TEST_DIR/$bin_b"
            cp "$src_b" "$TEST_DIR2/$bin_b"
        else
            printf "${YELLOW}ŌÜĀ '%s' not found, skipping${RESET}\n" "$bin_b"
            bin_b=""
        fi
    fi

    if [ ! -x "$infector" ]; then
        printf "${RED}ŌÜĀ Infector '%s' not found ŌĆö aborting chain${RESET}\n" "$infector_label"
        break
    fi

    infector_fp=$(strings "$infector" | grep "$SIGNATURE" | grep -o '\[[0-9A-F]*\]' | tr -d '[]')

    timeout "$TIMEOUT" "$infector" </dev/null >/dev/null 2>/dev/null
    sleep 1

    new_infector_fp=$(strings "$infector" | grep "$SIGNATURE" | grep -o '\[[0-9A-F]*\]' | tr -d '[]')

    # Determine fp change and chain status
    local_step=$(( i / 2 + 1 ))
    if [ "$infector_fp" != "$new_infector_fp" ] && [ -n "$new_infector_fp" ]; then
        fp_color="$GREEN"
        chain_note=""
        ((CHANGE_SIG_OK++))
    elif [ -z "$new_infector_fp" ] && [ "$CHAIN_BROKEN" -eq 0 ]; then
        fp_color="$RED"
        chain_note=" ${RED}ŌåÉ chain broken here${RESET}"
        CHAIN_BROKEN=1
        ((FAIL_SIG_CHANGE++))
    else
        fp_color="$RED"
        chain_note=""
        ((FAIL_SIG_CHANGE++))
    fi

    # Step header
    if [ -n "$bin_b" ]; then
        printf "${CYAN}[%2d]${RESET} ${BOLD}%-8s${RESET} ŌåÆ ${BLUE}%-8s %-8s${RESET}" \
            "$local_step" "$infector_label" "$bin_a" "$bin_b"
    else
        printf "${CYAN}[%2d]${RESET} ${BOLD}%-8s${RESET} ŌåÆ ${BLUE}%-8s         ${RESET}" \
            "$local_step" "$infector_label" "$bin_a"
    fi

    # Inline results
    run_test "$bin_a"
    [ -n "$bin_b" ] && run_test "$bin_b"

    # Fingerprint ŌĆö end of the row
    printf "  fingerprint:${fp_color}[%s]ŌåÆ[%s]${RESET}%s\n" \
        "$infector_fp" "$new_infector_fp" "$chain_note"

    # Flush any buffered KO diffs below the row
    flush_diffs

done

# ------------------------------------------------
# Anti-debug + anti-process tests
# ------------------------------------------------

printf "\n${BOLD}======= Anti-Debug / Anti-Process =======${RESET}\n\n"

if ! command -v gdb &>/dev/null; then
    printf "${YELLOW}ŌÜĀ gdb not found ŌĆö skipping anti-debug tests${RESET}\n"
else
    antidebug_test "war under gdb"                           "$(pwd)/war"
    antidebug_test "infected '${TARGETS[0]}' under gdb"     "$TEST_DIR/${TARGETS[0]}"
fi

antiprocess_test "war with doom-nukem running"                        "$(pwd)/war"
antiprocess_test "infected '${TARGETS[0]}' with doom-nukem running"  "$TEST_DIR/${TARGETS[0]}"

# ------------------------------------------------
# Final summary
# ------------------------------------------------

printf "\n${BOLD}============ SUMMARY ============${RESET}\n"
printf "Binaries: ${BOLD}%d${RESET}  " "$TOTAL"

printf "Behavior: "
[ "$BEHAVIOR_OK" -eq "$TOTAL" ] \
    && printf "${GREEN}Ō£ō %d/%d${RESET}  " "$BEHAVIOR_OK" "$TOTAL" \
    || printf "${RED}Ō£Ś %d/%d${RESET}  " "$BEHAVIOR_OK" "$TOTAL"

printf "Signature: "
[ "$SIGNATURE_OK" -eq "$TOTAL" ] \
    && printf "${GREEN}Ō£ō %d/%d${RESET}  " "$SIGNATURE_OK" "$TOTAL" \
    || printf "${RED}Ō£Ś %d/%d${RESET}  " "$SIGNATURE_OK" "$TOTAL"

printf "FP-change: "
[ "$FAIL_SIG_CHANGE" -eq 0 ] \
    && printf "${GREEN}Ō£ō %d/%d${RESET}  " "$CHANGE_SIG_OK" "$((CHANGE_SIG_OK + FAIL_SIG_CHANGE))" \
    || printf "${RED}Ō£Ś %d/%d${RESET}  " "$CHANGE_SIG_OK" "$((CHANGE_SIG_OK + FAIL_SIG_CHANGE))"

if [ "$ANTIDEBUG_TOTAL" -gt 0 ]; then
    printf "Antidebug: "
    [ "$ANTIDEBUG_OK" -eq "$ANTIDEBUG_TOTAL" ] \
        && printf "${GREEN}Ō£ō %d/%d${RESET}" "$ANTIDEBUG_OK" "$ANTIDEBUG_TOTAL" \
        || printf "${RED}Ō£Ś %d/%d${RESET}" "$ANTIDEBUG_OK" "$ANTIDEBUG_TOTAL"
fi

printf "\n${BOLD}=================================${RESET}\n\n"

exit 0
